# Postgres (Neon connection string — pooled URL recommended for serverless)
DATABASE_URL=postgres://USER:PASSWORD@HOST/DBNAME?sslmode=require

# Ticketmaster Discovery API — get a key at https://developer.ticketmaster.com/
TICKETMASTER_API_KEY=

# Vercel Cron auth — generate any random string, set the same value
# in Vercel project env vars. Vercel sends it as `Authorization: Bearer ...`.
# Locally: not required unless you call /api/cron/ingest yourself.
CRON_SECRET=
