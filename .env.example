# Postgres (Neon connection string — pooled URL recommended for serverless)
DATABASE_URL=postgres://USER:PASSWORD@HOST/DBNAME?sslmode=require

# Ticketmaster Discovery API — get a key at https://developer.ticketmaster.com/
TICKETMASTER_API_KEY=

# Vercel Cron auth — generate any random string, set the same value
# in Vercel project env vars. Vercel sends it as `Authorization: Bearer ...`.
# Locally: not required unless you call /api/cron/ingest yourself.
CRON_SECRET=

# Random 32+ char secret used to sign the admin session cookie (HMAC).
# Generate one: `openssl rand -hex 32`.
SESSION_SECRET=

# Comma-separated allowlist of Google account emails permitted to access
# the /admin dashboard.
ADMIN_EMAILS=

# Google OAuth credentials for admin sign-in.
# 1. https://console.cloud.google.com/apis/credentials  → Create Credentials → OAuth client ID → Web application
# 2. Add Authorized redirect URIs:
#      https://<your-prod-domain>/api/admin/auth/google/callback
#      http://localhost:3000/api/admin/auth/google/callback   (for local dev)
# 3. Copy Client ID and Client secret here.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Resend API key for magic-link emails (https://resend.com — free tier 100/day).
# Verify a domain on Resend, then use it for MAGIC_LINK_FROM.
RESEND_API_KEY=

# Email "From" address. For testing, you can use onboarding@resend.dev
# (no domain verification needed). For production, use an address on a
# domain you've verified DKIM/SPF for in your Resend account.
MAGIC_LINK_FROM=onboarding@resend.dev

# Optional override for the base URL used in magic-link emails. If unset,
# derived from the incoming request host. Set this if your prod URL differs.
PUBLIC_BASE_URL=

# Stripe (consumer no-ads tier).
# 1. Create a Stripe account, switch to Live mode when ready.
# 2. Products → New Product: "Proactivity Plus" → recurring price ($4.99/month).
#    Copy the price ID (price_...) and set STRIPE_PRICE_NO_ADS.
# 3. Developers → API keys → copy the secret key.
# 4. Developers → Webhooks → Add endpoint:
#       https://<your-prod-domain>/api/billing/webhook
#    Events to listen for:
#       checkout.session.completed
#       customer.subscription.created
#       customer.subscription.updated
#       customer.subscription.deleted
#    Copy the signing secret (whsec_...) to STRIPE_WEBHOOK_SECRET.
STRIPE_SECRET_KEY=
STRIPE_PRICE_NO_ADS=
STRIPE_PRICE_ORGANIZER_PRO=
STRIPE_WEBHOOK_SECRET=

# Resend "From" address for organizer notifications (claim/draft/url
# resolved). Defaults to MAGIC_LINK_FROM when unset.
NOTIFICATIONS_FROM=

# Comma-separated recipients for admin "needs review" emails — sent
# whenever a new pending item lands in any moderation queue (claims,
# event drafts, URL submissions, contact form, ratings). Defaults to
# ADMIN_EMAILS if unset.
ADMIN_NOTIFICATION_EMAIL=

# Google AdSense.
# 1. Sign up at https://adsense.google.com — submit your site for approval.
# 2. Your client ID is the "ca-pub-..." string in the snippet AdSense shows
#    you. The site must be approved before ads will actually serve, but the
#    script can be added beforehand.
# 3. Create ad units in the AdSense dashboard (Ads → By ad unit):
#      - one "Display ad" (responsive) for the top-of-list banner
#      - one "In-feed ad" for the in-list slot
#    Each ad unit gives you a numeric slot ID — paste them below.
# 4. Without slot IDs the AdSlot component renders nothing.
NEXT_PUBLIC_ADSENSE_CLIENT_ID=
NEXT_PUBLIC_ADSENSE_SLOT_TOP=
NEXT_PUBLIC_ADSENSE_SLOT_INFEED=
