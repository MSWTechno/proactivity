{
  "name": "proactivity",
  "private": true,
  "version": "0.0.0",
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "pnpm --filter @proactivity/web dev",
    "build": "pnpm -r build",
    "ingest": "pnpm --filter @proactivity/ingestion start",
    "sources:add": "pnpm --filter @proactivity/ingestion sources add",
    "sources:list": "pnpm --filter @proactivity/ingestion sources list",
    "sources:disable": "pnpm --filter @proactivity/ingestion sources disable",
    "sources:set": "pnpm --filter @proactivity/ingestion sources set",
    "ratings:list": "pnpm --filter @proactivity/ingestion ratings list",
    "ratings:approve": "pnpm --filter @proactivity/ingestion ratings approve",
    "ratings:reject": "pnpm --filter @proactivity/ingestion ratings reject",
    "sync:env": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/sync-env-to-vercel.ps1",
    "deploy:prod": "vercel deploy --prod --cwd apps/web",
    "db:generate": "pnpm --filter @proactivity/db generate",
    "db:migrate": "pnpm --filter @proactivity/db migrate",
    "typecheck": "pnpm -r typecheck"
  },
  "devDependencies": {
    "typescript": "^5.6.0"
  }
}
