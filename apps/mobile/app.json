{
  "expo": {
    "name": "Proactivity",
    "slug": "proactivity",
    "version": "0.1.0",
    "scheme": "proactivity",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.mswtechno.proactivity"
    },
    "android": {
      "package": "com.mswtechno.proactivity",
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "plugins": [
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Allow Proactivity to use your location to show nearby events."
        }
      ],
      [
        "react-native-google-mobile-ads",
        {
          "androidAppId": "ca-app-pub-3940256099942544~3347511713",
          "iosAppId": "ca-app-pub-3940256099942544~1458002511"
        }
      ]
    ],
    "extra": {
      "apiBaseUrl": "https://proactivity-web.vercel.app",
      "adMobBannerUnitIdAndroid": "",
      "adMobBannerUnitIdIos": "",
      "adMobInFeedUnitIdAndroid": "",
      "adMobInFeedUnitIdIos": "",
      "eas": {
        "projectId": "e52b81d3-d059-4f0d-83c4-f9d4abab51de"
      }
    },
    "owner": "mswtechnologies",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/e52b81d3-d059-4f0d-83c4-f9d4abab51de"
    }
  }
}
