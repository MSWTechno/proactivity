{
  "expo": {
    "name": "Proactivity",
    "slug": "proactivity",
    "version": "0.1.0",
    "scheme": "proactivity",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#6d28d9"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.mswtechno.proactivity",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.mswtechno.proactivity",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#6d28d9"
      },
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Allow Proactivity to use your location to show nearby events."
        }
      ],
      [
        "react-native-google-mobile-ads",
        {
          "androidAppId": "ca-app-pub-8679774689772691~6293863061",
          "iosAppId": "ca-app-pub-8679774689772691~3667699727",
          "delayAppMeasurementInit": true,
          "optimizeInitialization": true,
          "optimizeAdLoading": true,
          "userTrackingUsageDescription": "This identifier will be used to deliver personalized ads to you."
        }
      ]
    ],
    "extra": {
      "apiBaseUrl": "https://proactivity.app",
      "adMobBannerUnitIdAndroid": "ca-app-pub-8679774689772691/4142799291",
      "adMobBannerUnitIdIos": "ca-app-pub-8679774689772691/4920694343",
      "adMobInFeedUnitIdAndroid": "ca-app-pub-8679774689772691/6066255053",
      "adMobInFeedUnitIdIos": "ca-app-pub-8679774689772691/5140563498",
      "eas": {
        "projectId": "e52b81d3-d059-4f0d-83c4-f9d4abab51de"
      }
    },
    "owner": "mswtechnologies",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/e52b81d3-d059-4f0d-83c4-f9d4abab51de"
    }
  }
}
